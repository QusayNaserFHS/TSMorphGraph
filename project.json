{
  "name": "tsmorph-graph",
  "$schema": "node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc"
      },
      "outputs": ["{projectRoot}/dist"]
    },
    "analyze": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx src/cli.ts"
      }
    },
    "generate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx src/generate-test-data.ts"
      }
    }
  }
}
